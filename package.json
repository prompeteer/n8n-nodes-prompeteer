{
    "name": "n8n-nodes-prompeteer",
    "version": "0.1.0",
    "description": "n8n community node for Prompeteer.ai — generate, score, and enhance AI prompts for 140+ platforms",
    "keywords": [
          "n8n-community-node-package",
          "n8n",
          "prompeteer",
          "prompt-engineering",
          "ai",
          "llm",
          "prompt-score",
          "promptdrive",
          "auto-save"
    ],
    "license": "MIT",
    "homepage": "https://prompeteer.ai/connect",
    "author": {
          "name": "Prompeteer.ai",
          "email": "info@prompeteer.com",
          "url": "https://prompeteer.ai"
    },
    "repository": {
          "type": "git",
          "url": "https://github.com/prompeteer/n8n-nodes-prompeteer.git"
    },
    "main": "dist/nodes/Prompeteer/Prompeteer.node.js",
    "scripts": {
          "build": "tsc && gulp build:icons",
          "dev": "tsc --watch",
          "lint": "tsc --noEmit",
          "prepublishOnly": "npm run build"
    },
    "files": [
          "dist"
    ],
    "n8n": {
          "n8nNodesApiVersion": 1,
          "credentials": [
                  "dist/credentials/PrompeteerApi.credentials.js"
          ],
          "nodes": [
                  "dist/nodes/Prompeteer/Prompeteer.node.js"
          ]
    },
    "devDependencies": {
          "@types/node": "^20.0.0",
          "gulp": "^4.0.2",
          "n8n-workflow": "^1.0.0",
          "typescript": "^5.3.0"
    },
    "peerDependencies": {
          "n8n-workflow": "*"
    }
}
